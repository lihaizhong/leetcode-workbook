{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "outDir": "./release",
    "module": "ESNext"
  },
  "exclude": [
    "node_modules",
    "release",
    "**/*.config.ts",
    "**/__tests__/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "include": [
    "./*.ts"
  ]
}